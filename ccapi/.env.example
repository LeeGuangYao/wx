# 服务端口
PORT=3000

# 对外访问地址（可选）
# 留空：自动根据请求的 Host 头动态拼接图片 URL（推荐，适配多环境）
# 配置：强制使用该值（例如接入 CDN 或自定义域名时）
# BASE_URL=https://api.example.com

# SQLite 数据库文件路径
DB_PATH=./data/meal.db

# 图片上传目录（相对路径或绝对路径）
UPLOAD_DIR=./uploads

# 单张图片大小限制（字节），默认 10MB
MAX_FILE_SIZE=10485760

# 单次最多上传图片数量
MAX_FILES=9

# 微信小程序登录
WX_APPID=你的appid
WX_SECRET=你的secret
JWT_SECRET=请替换为随机长字符串

# 管理员 openid 列表（逗号分隔），管理员可查看所有用户数据
ADMIN_OPENIDS=
