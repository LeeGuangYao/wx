<view class="tab-bar" wx:if="{{list.length}}">
  <view class="tab-bar-bg"></view>
  <view
    wx:for="{{list}}"
    wx:key="pagePath"
    class="tab-item {{selected === index ? 'tab-item-on' : ''}}"
    data-path="{{item.pagePath}}"
    data-index="{{index}}"
    bindtap="switchTab"
  >
    <view class="tab-icon-wrap">
      <image
        class="tab-icon"
        src="{{selected === index ? item.iconSel : item.icon}}"
        mode="aspectFit"
      />
      <view wx:if="{{selected === index}}" class="tab-glow"></view>
    </view>
    <text class="tab-label">{{item.text}}</text>
    <view wx:if="{{selected === index}}" class="tab-dot"></view>
  </view>
</view>
