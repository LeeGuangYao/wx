/* ============================================================
 *  精选分类页（Category）
 *  · 与首页保持一致的暖色头图 + 米白底
 *  · 左侧分类导航 / 右侧菜谱列表 + 触底懒加载
 * ============================================================ */
page {
  background: var(--color-bg);
  height: 100%;
}

.page {
  position: relative;
  display: flex;
  flex-direction: column;
  height: 100vh;
  padding-bottom: calc(110rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ── 顶部暖色渐变 ── */
.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 320rpx;
  background: linear-gradient(175deg, #FF6B35 0%, #FF8A5B 50%, rgba(250, 246, 240, 0) 100%);
  z-index: 0;
}

.top-bg::before {
  content: '';
  position: absolute;
  right: -60rpx;
  top: 40rpx;
  width: 220rpx;
  height: 220rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0) 70%);
  border-radius: 50%;
}

/* ── Header ── */
.header {
  position: relative;
  z-index: 1;
  padding: 40rpx var(--sp-5) var(--sp-3);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  flex-shrink: 0;
}

.brand {
  display: flex;
  flex-direction: column;
}

.brand-title {
  font-size: var(--fs-display);
  font-weight: 700;
  color: #fff;
  line-height: 1.15;
  letter-spacing: 2rpx;
}

.brand-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
  letter-spacing: 1rpx;
}

.header-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.20);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  padding: 14rpx 24rpx;
  border-radius: var(--r-lg);
  border: 1.5rpx solid rgba(255, 255, 255, 0.34);
  min-width: 104rpx;
}

.stat-num {
  font-size: var(--fs-h1);
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.90);
  letter-spacing: 1rpx;
}

/* ── 主体布局：左右两栏 ── */
.body {
  position: relative;
  z-index: 1;
  flex: 1;
  display: flex;
  min-height: 0;
  margin-top: var(--sp-2);
}

/* ── 左侧分类 ── */
.side {
  width: 200rpx;
  flex-shrink: 0;
  background: var(--color-surface);
  border-top-right-radius: var(--r-xl);
  box-shadow: 0 8rpx 24rpx rgba(42, 33, 24, 0.06);
  padding: var(--sp-2) 0;
}

.side-item {
  position: relative;
  padding: 26rpx 24rpx 26rpx 28rpx;
  display: flex;
  align-items: center;
  transition: background 0.18s;
}

.side-item:active {
  background: var(--color-primary-bg);
}

.side-item-on {
  background: var(--color-bg);
}

.side-bar {
  position: absolute;
  left: 0;
  top: 50%;
  transform: translateY(-50%);
  width: 6rpx;
  height: 36rpx;
  background: var(--color-primary);
  border-radius: 0 4rpx 4rpx 0;
}

.side-text-wrap {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  flex: 1;
  min-width: 0;
}

.side-name {
  font-size: 28rpx;
  color: var(--color-text-2);
  font-weight: 500;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.side-item-on .side-name {
  color: var(--color-primary);
  font-weight: 700;
}

.side-count {
  font-size: 20rpx;
  color: var(--color-text-5);
  letter-spacing: 0.5rpx;
}

.side-item-on .side-count {
  color: var(--color-primary-soft);
}

/* ── 右侧菜谱列表 ── */
.main {
  flex: 1;
  min-width: 0;
  padding: var(--sp-2) var(--sp-4) 0;
  box-sizing: border-box;
}

.anchor {
  height: 1rpx;
}

.list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
  padding-bottom: var(--sp-4);
}

.card {
  display: flex;
  gap: 24rpx;
  background: var(--color-surface);
  border-radius: var(--r-lg);
  padding: var(--sp-3);
  box-shadow: var(--shadow-md);
  transition: transform 0.15s, box-shadow 0.15s;
}

.card:active {
  transform: scale(0.98);
  box-shadow: var(--shadow-sm);
}

.card-avatar {
  position: relative;
  flex-shrink: 0;
  width: 112rpx;
  height: 112rpx;
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 22rpx rgba(255, 94, 58, 0.24);
  overflow: hidden;
}

.card-avatar::after {
  content: '';
  position: absolute;
  right: -24rpx;
  bottom: -24rpx;
  width: 96rpx;
  height: 96rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 70%);
  border-radius: 50%;
}

.card-initial {
  position: relative;
  z-index: 1;
  font-size: 52rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.card-name {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-1);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
}

.card-tag-row {
  margin-top: 2rpx;
}

.card-tag {
  display: inline-block;
  font-size: 20rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 4rpx 14rpx;
  border-radius: 8rpx;
  font-weight: 500;
}

.card-desc {
  font-size: 23rpx;
  color: var(--color-text-3);
  line-height: 1.55;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── 状态：加载 / 错误 / 空态 ── */
.state {
  padding: 100rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-3);
}

.state-full {
  flex: 1;
  justify-content: center;
}

.state-dot {
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  border: 4rpx solid #FFD4BF;
  border-top-color: var(--color-primary);
  animation: spin 0.8s linear infinite;
}

.state-dot.small {
  width: 32rpx;
  height: 32rpx;
  border-width: 3rpx;
}

@keyframes spin { to { transform: rotate(360deg); } }

.state-text {
  font-size: var(--fs-body);
  color: var(--color-text-3);
}

.state-text.error {
  color: var(--color-error);
}

.state-btn {
  margin-top: 8rpx;
  padding: 18rpx 44rpx;
  background: var(--grad-primary);
  color: #fff;
  font-size: var(--fs-body);
  font-weight: 500;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-primary);
}

.empty {
  padding: 120rpx 32rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-ico {
  width: 140rpx;
  height: 140rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 64rpx;
  color: var(--color-primary-soft);
  margin-bottom: var(--sp-3);
}

.empty-title {
  font-size: 30rpx;
  color: var(--color-text-2);
  font-weight: 600;
  letter-spacing: 1rpx;
}

/* ── 列表底部 ── */
.list-end {
  padding: 32rpx 0 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
}

.list-end-text {
  font-size: 22rpx;
  color: var(--color-text-5);
  letter-spacing: 2rpx;
}
