/* ============================================================
 *  食记 · 列表
 *  · 顶部："FOOD DIARY" 标识 + 大标题 + 条数标签
 *  · 卡片：时间点 · 标题 · 正文 · 图片网格（1/2/3/4/9 宫格）
 *  · 图片：统一圆角 + 1:1 / 4:3 比例 · 突出显示
 *  · 浮动 "+ 写一餐" 按钮
 * ============================================================ */
page {
  background: var(--color-bg);
}

.page {
  position: relative;
  min-height: 100vh;
  padding: var(--sp-3) var(--sp-4) calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ── 背景柔光 ── */
.bg-decor {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 360rpx;
  background: var(--grad-bg-warm);
  z-index: 0;
}

/* ── 顶部 ── */
.topbar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: var(--sp-2) 8rpx var(--sp-5);
}

.topbar-left {
  display: flex;
  flex-direction: column;
}

.topbar-sub {
  font-size: var(--fs-tiny);
  color: var(--color-text-4);
  letter-spacing: 4rpx;
  font-weight: 500;
}

.topbar-title {
  margin-top: 8rpx;
  font-size: var(--fs-display);
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.topbar-count {
  display: flex;
  align-items: baseline;
  gap: 6rpx;
  background: var(--color-surface);
  padding: 14rpx 26rpx;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-md);
}

.topbar-count-num {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-primary);
  line-height: 1;
}

.topbar-count-label {
  font-size: var(--fs-tiny);
  color: var(--color-text-3);
}

/* ── 状态 ── */
.state {
  padding: 180rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-3);
}

.state-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 4rpx solid #FFD4BF;
  border-top-color: var(--color-primary);
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.state-emoji {
  font-size: 88rpx;
  line-height: 1;
}

.state-text {
  font-size: var(--fs-body);
  color: var(--color-text-3);
}

.state-text.error { color: var(--color-error); }

.state-btn {
  margin-top: 8rpx;
  padding: 20rpx 48rpx;
  background: var(--grad-primary);
  color: #fff;
  font-size: var(--fs-body);
  font-weight: 500;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-primary);
}

/* ── 列表 ── */
.list {
  position: relative;
  z-index: 1;
}

.card {
  background: var(--color-surface);
  border-radius: var(--r-xl);
  padding: 28rpx 28rpx var(--sp-3);
  margin-bottom: var(--sp-3);
  box-shadow: var(--shadow-md);
}

.card-head {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.card-dot {
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: var(--grad-primary);
  margin-right: 14rpx;
  box-shadow: 0 2rpx 6rpx rgba(255, 94, 58, 0.42);
}

.card-time {
  font-size: var(--fs-small);
  color: var(--color-text-4);
  letter-spacing: 0.5rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-1);
  line-height: 1.4;
  margin-bottom: 10rpx;
  letter-spacing: 0.5rpx;
}

.card-content {
  font-size: var(--fs-body);
  color: var(--color-text-2);
  line-height: 1.7;
  margin-bottom: 18rpx;
  word-break: break-all;
  white-space: pre-wrap;
}

/* ── 图片网格（统一圆角 · 统一比例） ── */
.card-imgs {
  display: grid;
  gap: 10rpx;
  margin-top: 6rpx;
}

.grid-1 { grid-template-columns: 1fr; }
.grid-1 .card-img {
  width: 100%;
  height: 440rpx;     /* 单图：更大 · 4:3 近似 */
  border-radius: var(--r-md);
}

.grid-2 { grid-template-columns: repeat(2, 1fr); }
.grid-2 .card-img {
  width: 100%;
  height: 300rpx;
  border-radius: 18rpx;
}

.grid-3 { grid-template-columns: repeat(3, 1fr); }
.grid-3 .card-img {
  width: 100%;
  height: 210rpx;
  border-radius: 14rpx;
}

.card-img {
  background: var(--color-border);
  display: block;
  box-shadow: inset 0 0 0 1rpx rgba(42, 33, 24, 0.04);
}

/* ── 底部 ── */
.footer {
  padding: var(--sp-4) 0 12rpx;
  text-align: center;
}

.footer-text {
  font-size: var(--fs-small);
  color: var(--color-text-5);
  letter-spacing: 1rpx;
}

/* ── 浮动新增按钮 ── */
.fab {
  position: fixed;
  right: 40rpx;
  bottom: calc(160rpx + env(safe-area-inset-bottom));
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--grad-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: var(--shadow-float);
  z-index: 10;
  transition: transform 0.15s, opacity 0.15s;
}

.fab-hover {
  opacity: 0.9;
  transform: scale(0.94);
}

.fab-ico {
  color: #fff;
  font-size: 64rpx;
  line-height: 1;
  font-weight: 300;
  margin-top: -4rpx;
}
