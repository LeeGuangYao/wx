/* ============================================================
 *  食记 · 记录（Meal create）
 *  · 顶部暖色柔光
 *  · 分段卡片：图片 / 标题 / 正文
 *  · 图片区域：圆角 20rpx · 1:1 · 9 宫格
 *  · 主按钮：暖色渐变 · 阴影高亮
 * ============================================================ */
page {
  background: var(--color-bg);
}

.page {
  position: relative;
  min-height: 100vh;
  padding: var(--sp-3) var(--sp-4) calc(180rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ── 背景柔光 ── */
.bg-decor {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 420rpx;
  background: var(--grad-bg-warm);
  z-index: 0;
}

/* ── 顶部 ── */
.topbar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: var(--sp-2) 8rpx 8rpx;
}

.topbar-left {
  display: flex;
  flex-direction: column;
}

.topbar-date {
  font-size: 23rpx;
  color: var(--color-text-4);
  letter-spacing: 1rpx;
}

.topbar-title {
  margin-top: 8rpx;
  font-size: var(--fs-display);
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.topbar-entry {
  display: flex;
  align-items: center;
  gap: 8rpx;
  background: var(--color-surface);
  padding: 14rpx 24rpx;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-md);
  transition: opacity 0.15s, transform 0.15s;
}

.topbar-entry-hover {
  opacity: 0.85;
  transform: scale(0.97);
}

.topbar-entry-ico {
  font-size: 28rpx;
  line-height: 1;
}

.topbar-entry-text {
  font-size: var(--fs-small);
  color: var(--color-text-2);
  font-weight: 600;
  letter-spacing: 0.5rpx;
}

.hint-row {
  position: relative;
  z-index: 1;
  padding: 14rpx 8rpx var(--sp-4);
}

.hint-text {
  font-size: var(--fs-small);
  color: var(--color-text-3);
  letter-spacing: 0.5rpx;
}

/* ── 卡片 ── */
.card {
  position: relative;
  z-index: 1;
  margin-bottom: var(--sp-3);
  background: var(--color-surface);
  border-radius: var(--r-xl);
  padding: var(--sp-4);
  box-shadow: var(--shadow-md);
}

.card-head {
  display: flex;
  align-items: center;
  margin-bottom: var(--sp-3);
}

.card-bar {
  width: 6rpx;
  height: 30rpx;
  background: var(--grad-primary);
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.card-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: 0.5rpx;
  flex: 1;
}

.card-sub {
  font-size: var(--fs-tiny);
  color: var(--color-text-4);
}

/* ── 图片区 ── */
.img-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.img-add {
  width: 196rpx;
  height: 196rpx;
  border-radius: var(--r-md);
  background: var(--color-primary-bg);
  border: 2rpx dashed #FFB894;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  transition: opacity 0.15s, transform 0.15s;
}

.img-add:active {
  opacity: 0.72;
  transform: scale(0.97);
}

.img-add-plus {
  font-size: 64rpx;
  color: var(--color-primary-soft);
  line-height: 1;
  font-weight: 300;
}

.img-add-text {
  font-size: var(--fs-tiny);
  color: var(--color-text-4);
}

.img-wrap {
  position: relative;
  width: 196rpx;
  height: 196rpx;
}

.img-thumb {
  width: 196rpx;
  height: 196rpx;
  border-radius: var(--r-md);
  background: var(--color-border);
}

.img-remove {
  position: absolute;
  top: -14rpx;
  right: -14rpx;
  width: 48rpx;
  height: 48rpx;
  border-radius: 50%;
  background: rgba(42, 33, 24, 0.78);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4rpx 12rpx rgba(0, 0, 0, 0.20);
}

.img-remove-ico {
  color: #fff;
  font-size: 34rpx;
  line-height: 1;
  margin-top: -4rpx;
}

/* ── 输入 ── */
.input {
  width: 100%;
  font-size: 30rpx;
  color: var(--color-text-1);
  padding: 8rpx 0;
  box-sizing: border-box;
}

.textarea {
  width: 100%;
  min-height: 200rpx;
  font-size: var(--fs-body);
  color: var(--color-text-1);
  line-height: 1.75;
  padding: 8rpx 0;
  box-sizing: border-box;
}

.input-ph {
  color: var(--color-text-4);
}

/* ── 提交 ── */
.submit-row {
  position: relative;
  z-index: 1;
  margin-top: 12rpx;
}

.btn {
  width: 100%;
  height: 104rpx;
  border-radius: var(--r-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 14rpx;
  font-weight: 600;
  border: none;
  padding: 0;
}

.btn::after { border: none; }

.btn-primary {
  background: var(--grad-primary);
  color: #fff;
  box-shadow: var(--shadow-primary);
}

.btn-hover { opacity: 0.92; }

.btn-disabled {
  background: #E8DFD5 !important;
  color: #fff !important;
  box-shadow: none !important;
}

.btn-ico { font-size: 34rpx; line-height: 1; }
.btn-label { font-size: 32rpx; letter-spacing: 2rpx; }

/* ── 底部提示 ── */
.tip-row {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-4);
  text-align: center;
}

.tip-text {
  font-size: var(--fs-tiny);
  color: var(--color-text-5);
  letter-spacing: 0.5rpx;
}
