/* ============================================================
 *  菜谱详情
 *  · 顶部 Hero：主色渐变 + 大标题 + 统计数字
 *  · 原料 / 调料 / 步骤 / 小贴士 四段式卡片
 *  · 固定底部操作栏（收藏 + 分享）
 *  注：详情页非 Tab 页，不需 tabBar 预留空间
 * ============================================================ */
page {
  background: var(--color-bg);
}

.page {
  min-height: 100vh;
  padding-bottom: 200rpx;
}

/* ── 状态 ── */
.state-text {
  text-align: center;
  color: var(--color-text-3);
  margin-top: 140rpx;
  font-size: var(--fs-body);
}

.state-text.error { color: var(--color-error); }

/* ── Hero ── */
.hero {
  position: relative;
  padding: var(--sp-6) 44rpx 60rpx;
  border-bottom-left-radius: 52rpx;
  border-bottom-right-radius: 52rpx;
  color: #fff;
  box-shadow: 0 24rpx 64rpx rgba(255, 94, 58, 0.28);
  overflow: hidden;
}

.hero::before {
  content: '';
  position: absolute;
  right: -70rpx;
  top: -70rpx;
  width: 340rpx;
  height: 340rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.hero::after {
  content: '';
  position: absolute;
  left: -60rpx;
  bottom: -60rpx;
  width: 240rpx;
  height: 240rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-tag {
  font-size: var(--fs-small);
  color: #fff;
  background: rgba(255, 255, 255, 0.24);
  padding: 10rpx 26rpx;
  border-radius: var(--r-full);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.fav-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.fav-btn.fav-on { background: #fff; }
.fav-btn:active { transform: scale(0.9); }

.fav-icon {
  font-size: 38rpx;
  color: #fff;
  line-height: 1;
}

.fav-btn.fav-on .fav-icon { color: var(--color-primary); }

.hero-body {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-5);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-badge {
  width: 128rpx;
  height: 128rpx;
  border-radius: var(--r-lg);
  background: rgba(255, 255, 255, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.30);
}

.hero-initial {
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.hero-name {
  margin-top: var(--sp-4);
  font-size: 54rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  letter-spacing: 2rpx;
}

.hero-sub {
  margin-top: 16rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.86);
  line-height: 1.65;
}

/* ── 统计 ── */
.meta-row {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-6);
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.18);
  border-radius: var(--r-lg);
  padding: 28rpx 0;
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
}

.meta-cell { flex: 1; display: flex; flex-direction: column; align-items: center; }

.meta-num {
  font-size: 42rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.meta-label {
  margin-top: 8rpx;
  font-size: var(--fs-tiny);
  color: rgba(255, 255, 255, 0.84);
  letter-spacing: 0.5rpx;
}

.meta-divider {
  width: 1.5rpx;
  height: 52rpx;
  background: rgba(255, 255, 255, 0.24);
}

/* ── 内容卡片 ── */
.content {
  padding: var(--sp-4) 28rpx 0;
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

.card {
  background: var(--color-surface);
  border-radius: var(--r-xl);
  padding: var(--sp-4);
  box-shadow: var(--shadow-md);
}

.card-head {
  display: flex;
  align-items: center;
  margin-bottom: 28rpx;
}

.card-bar {
  width: 6rpx;
  height: 34rpx;
  background: var(--grad-primary);
  border-radius: 3rpx;
  margin-right: 18rpx;
}

.card-bar-alt {
  background: var(--grad-honey);
}

.card-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: 0.5rpx;
}

.card-count {
  font-size: var(--fs-small);
  color: var(--color-text-4);
  font-weight: 500;
}

/* ── 食材 chips ── */
.chips {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.chip {
  font-size: 26rpx;
  color: var(--color-text-2);
  background: var(--color-primary-bg);
  padding: 14rpx 26rpx;
  border-radius: 18rpx;
  border: 1rpx solid var(--color-border-warm);
  font-weight: 500;
}

.chip-alt {
  background: var(--color-accent-bg);
  color: #8A5A2B;
  border-color: var(--color-accent-bd);
}

/* ── 步骤 ── */
.steps {
  display: flex;
  flex-direction: column;
  gap: 28rpx;
}

.step {
  display: flex;
  align-items: flex-start;
  gap: var(--sp-3);
}

.step-num {
  flex-shrink: 0;
  width: 56rpx;
  height: 56rpx;
  border-radius: 18rpx;
  background: var(--grad-primary);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 16rpx rgba(255, 94, 58, 0.30);
  margin-top: 4rpx;
}

.step-num-text {
  font-size: 26rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.step-body {
  flex: 1;
  background: var(--color-surface-warm);
  border-radius: var(--r-lg);
  padding: 24rpx 28rpx;
  border: 1rpx solid var(--color-border);
}

.step-text {
  font-size: var(--fs-body);
  color: var(--color-text-2);
  line-height: 1.8;
}

/* ── 小贴士 ── */
.tip-card {
  background: linear-gradient(135deg, #FFF8EC 0%, #FFF2DC 100%);
  border: 1.5rpx solid var(--color-accent-bd);
}

.tip-head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.tip-icon {
  font-size: 28rpx;
  color: var(--color-warm-yolk);
  margin-right: 14rpx;
}

.tip-title {
  font-size: 30rpx;
  font-weight: 700;
  color: #8A5A2B;
  letter-spacing: 0.5rpx;
}

.tip-text {
  font-size: var(--fs-body);
  color: #6B4A20;
  line-height: 1.8;
}

.footer-space { height: 48rpx; }

/* ── 固定操作栏 ── */
.action-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 28rpx calc(24rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.94);
  backdrop-filter: blur(24rpx);
  -webkit-backdrop-filter: blur(24rpx);
  display: flex;
  gap: 20rpx;
  border-top: 1rpx solid var(--color-divider);
}

.action-btn {
  flex: 1;
  height: 96rpx;
  border-radius: var(--r-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-weight: 600;
  padding: 0;
  line-height: 1;
  transition: opacity 0.15s, transform 0.15s;
}

.action-btn:active { opacity: 0.85; transform: scale(0.98); }

.action-primary {
  background: var(--color-primary-bg);
  color: var(--color-primary);
  border: 1.5rpx solid var(--color-border-warm);
}

.action-primary-on {
  background: var(--grad-primary);
  color: #fff;
  border-color: transparent;
  box-shadow: var(--shadow-primary);
}

.action-share {
  background: linear-gradient(135deg, #3D2E24, #2A1F17);
  color: #fff;
}

.action-share::after { border: none; }

.action-icon { font-size: 32rpx; line-height: 1; }
.action-label { font-size: 28rpx; }
