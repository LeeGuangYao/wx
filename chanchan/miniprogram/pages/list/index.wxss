/* ============================================================
 *  菜谱列表页（List）
 *  · 顶部暖色渐变头图（主色）
 *  · 毛玻璃搜索框
 *  · 方形圆角卡片 + 原料摘要
 * ============================================================ */
page {
  background: var(--color-bg);
}

.page {
  position: relative;
  min-height: 100vh;
  padding-bottom: calc(160rpx + env(safe-area-inset-bottom));
}

/* ── 顶部暖色渐变 ── */
.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 460rpx;
  background: linear-gradient(175deg, #FF6B35 0%, #FF8A5B 50%, rgba(250, 246, 240, 0) 100%);
  z-index: 0;
}

.top-bg::before {
  content: '';
  position: absolute;
  right: -60rpx;
  top: 40rpx;
  width: 260rpx;
  height: 260rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.22), rgba(255, 255, 255, 0) 70%);
  border-radius: 50%;
}

/* ── Header ── */
.header {
  position: relative;
  z-index: 1;
  padding: 56rpx var(--sp-5) var(--sp-3);
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.brand {
  display: flex;
  flex-direction: column;
}

.brand-title {
  font-size: var(--fs-display);
  font-weight: 700;
  color: #fff;
  line-height: 1.15;
  letter-spacing: 2rpx;
}

.brand-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.82);
  letter-spacing: 1rpx;
}

.header-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.20);
  backdrop-filter: blur(14rpx);
  -webkit-backdrop-filter: blur(14rpx);
  padding: 16rpx 28rpx;
  border-radius: var(--r-lg);
  border: 1.5rpx solid rgba(255, 255, 255, 0.34);
  min-width: 104rpx;
}

.stat-num {
  font-size: var(--fs-h1);
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.90);
  letter-spacing: 1rpx;
}

/* ── 搜索框 ── */
.search-wrap {
  position: relative;
  z-index: 1;
  padding: var(--sp-3) var(--sp-4) 0;
}

.search {
  display: flex;
  align-items: center;
  background: var(--color-surface);
  border-radius: var(--r-xl);
  padding: 0 var(--sp-3);
  height: 92rpx;
  box-shadow: 0 14rpx 40rpx rgba(42, 33, 24, 0.12);
}

.search-icon {
  font-size: 36rpx;
  color: var(--color-primary);
  margin-right: 16rpx;
  line-height: 1;
  opacity: 0.88;
}

.search-input {
  flex: 1;
  font-size: var(--fs-body);
  color: var(--color-text-1);
  height: 92rpx;
}

.search-placeholder {
  color: var(--color-text-4);
  font-size: var(--fs-body);
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-clear-icon {
  font-size: 30rpx;
  color: var(--color-text-3);
  line-height: 1;
}

/* ── Tabs ── */
.tabs {
  position: relative;
  z-index: 1;
  padding: var(--sp-4) var(--sp-5) var(--sp-2);
  display: flex;
  gap: var(--sp-4);
}

.tab {
  position: relative;
  padding: 8rpx 0 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tab-label {
  font-size: var(--fs-body);
  color: rgba(255, 255, 255, 0.66);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.tab-on .tab-label {
  color: #fff;
  font-weight: 700;
  font-size: var(--fs-h2);
}

.tab-badge {
  background: rgba(255, 255, 255, 0.92);
  color: var(--color-primary-deep);
  font-size: 20rpx;
  font-weight: 700;
  padding: 3rpx 14rpx;
  border-radius: var(--r-full);
  line-height: 1.6;
}

.tab-dot {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #fff;
  border-radius: 2rpx;
}

/* ── 列表容器 ── */
.list-wrap {
  position: relative;
  z-index: 1;
  padding: var(--sp-1) var(--sp-4) 0;
}

/* ── 加载/错误/空态 ── */
.state {
  padding: 140rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-3);
}

.state-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 4rpx solid #FFD4BF;
  border-top-color: var(--color-primary);
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.state-text {
  font-size: var(--fs-body);
  color: var(--color-text-3);
}

.state-text.error {
  color: var(--color-error);
}

.state-btn {
  margin-top: 8rpx;
  padding: 20rpx 48rpx;
  background: var(--grad-primary);
  color: #fff;
  font-size: var(--fs-body);
  font-weight: 500;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-primary);
}

.empty {
  padding: 140rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-ico {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: var(--color-primary-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  color: var(--color-primary-soft);
  margin-bottom: var(--sp-4);
  box-shadow: inset 0 0 0 2rpx rgba(255, 138, 91, 0.16);
}

.empty-title {
  font-size: 34rpx;
  color: var(--color-text-2);
  font-weight: 600;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: var(--color-text-4);
  text-align: center;
  line-height: 1.7;
  max-width: 480rpx;
}

/* ── 菜谱列表 ── */
.list {
  display: flex;
  flex-direction: column;
  gap: var(--sp-3);
}

.card {
  display: flex;
  gap: 28rpx;
  background: var(--color-surface);
  border-radius: var(--r-xl);
  padding: var(--sp-4);
  box-shadow: var(--shadow-md);
  transition: transform 0.15s, box-shadow 0.15s;
}

.card:active {
  transform: scale(0.982);
  box-shadow: var(--shadow-sm);
}

/* 彩色渐变头像（食欲感） */
.card-avatar {
  position: relative;
  flex-shrink: 0;
  width: 144rpx;
  height: 144rpx;
  border-radius: var(--r-lg);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 10rpx 28rpx rgba(255, 94, 58, 0.26);
  overflow: hidden;
}

.card-avatar::after {
  content: '';
  position: absolute;
  right: -30rpx;
  bottom: -30rpx;
  width: 120rpx;
  height: 120rpx;
  background: radial-gradient(circle, rgba(255, 255, 255, 0.28), rgba(255, 255, 255, 0) 70%);
  border-radius: 50%;
}

.card-initial {
  position: relative;
  z-index: 1;
  font-size: 64rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
  text-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.12);
}

.card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.card-top {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.card-name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: var(--color-text-1);
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  letter-spacing: 0.5rpx;
}

.card-fav {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: var(--color-surface-soft);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.card-fav-on {
  background: var(--color-primary-bg-2);
}

.card-fav:active { transform: scale(0.88); }

.card-fav-icon {
  font-size: 30rpx;
  color: var(--color-text-5);
  line-height: 1;
}

.card-fav-on .card-fav-icon {
  color: var(--color-primary);
}

.card-tag-row {
  margin-bottom: 10rpx;
}

.card-tag {
  display: inline-block;
  font-size: 22rpx;
  color: var(--color-primary);
  background: var(--color-primary-bg);
  padding: 5rpx 18rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.card-desc {
  font-size: 25rpx;
  color: var(--color-text-3);
  line-height: 1.65;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.card-meta {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid var(--color-divider);
}

.card-meta-text {
  font-size: 23rpx;
  color: var(--color-text-4);
  letter-spacing: 0.5rpx;
}

.card-arrow {
  font-size: 36rpx;
  color: var(--color-text-5);
  line-height: 1;
}

/* ── 列表底部 ── */
.list-end {
  padding: 48rpx 0 24rpx;
  text-align: center;
}

.list-end-text {
  font-size: 22rpx;
  color: var(--color-text-5);
  letter-spacing: 3rpx;
}
