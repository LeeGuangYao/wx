page {
  background: #F7F4EF;
}

.page {
  position: relative;
  min-height: 100vh;
  padding-bottom: 80rpx;
}

/* ── Background gradient ── */
.top-bg {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 420rpx;
  background: linear-gradient(175deg, #FF6035 0%, #FF8A5B 58%, rgba(247, 244, 239, 0) 100%);
  z-index: 0;
}

/* ── Header ── */
.header {
  position: relative;
  z-index: 1;
  padding: 48rpx 40rpx 24rpx;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.brand {
  display: flex;
  flex-direction: column;
}

.brand-title {
  font-size: 56rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1.15;
  letter-spacing: 2rpx;
}

.brand-sub {
  margin-top: 12rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.80);
  letter-spacing: 1rpx;
}

.header-stat {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.20);
  backdrop-filter: blur(12rpx);
  padding: 16rpx 28rpx;
  border-radius: 24rpx;
  border: 1.5rpx solid rgba(255, 255, 255, 0.30);
  min-width: 100rpx;
}

.stat-num {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.stat-label {
  margin-top: 6rpx;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.88);
  letter-spacing: 1rpx;
}

/* ── Search ── */
.search-wrap {
  position: relative;
  z-index: 1;
  padding: 20rpx 32rpx 0;
}

.search {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 0 28rpx;
  height: 88rpx;
  box-shadow: 0 12rpx 36rpx rgba(42, 33, 24, 0.10);
}

.search-icon {
  font-size: 36rpx;
  color: #FF6B35;
  margin-right: 16rpx;
  line-height: 1;
  opacity: 0.85;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #2A2118;
  height: 88rpx;
}

.search-placeholder {
  color: #C4B5A5;
  font-size: 28rpx;
}

.search-clear {
  width: 44rpx;
  height: 44rpx;
  border-radius: 50%;
  background: #F0E7DB;
  display: flex;
  align-items: center;
  justify-content: center;
}

.search-clear-icon {
  font-size: 30rpx;
  color: #8A7865;
  line-height: 1;
}

/* ── Tabs ── */
.tabs {
  position: relative;
  z-index: 1;
  padding: 32rpx 40rpx 16rpx;
  display: flex;
  gap: 32rpx;
}

.tab {
  position: relative;
  padding: 8rpx 0 14rpx;
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.tab-label {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.60);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.tab-on .tab-label {
  color: #fff;
  font-weight: 700;
  font-size: 32rpx;
}

.tab-badge {
  background: rgba(255, 255, 255, 0.90);
  color: #FF5E3A;
  font-size: 20rpx;
  font-weight: 700;
  padding: 3rpx 14rpx;
  border-radius: 999rpx;
  line-height: 1.6;
}

.tab-dot {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  height: 4rpx;
  background: #fff;
  border-radius: 2rpx;
}

/* ── List wrapper ── */
.list-wrap {
  position: relative;
  z-index: 1;
  padding: 8rpx 28rpx 0;
}

/* ── State / Loading ── */
.state {
  padding: 140rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 28rpx;
}

.state-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 4rpx solid #FFD4BF;
  border-top-color: #FF5E3A;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.state-text {
  font-size: 28rpx;
  color: #8A7865;
}

.state-text.error {
  color: #E84B3C;
}

.state-btn {
  margin-top: 8rpx;
  padding: 20rpx 48rpx;
  background: #FF5E3A;
  color: #fff;
  font-size: 28rpx;
  font-weight: 500;
  border-radius: 999rpx;
  box-shadow: 0 8rpx 20rpx rgba(255, 94, 58, 0.28);
}

/* ── Empty state ── */
.empty {
  padding: 140rpx 48rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.empty-ico {
  width: 152rpx;
  height: 152rpx;
  border-radius: 50%;
  background: #FFF0E6;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 72rpx;
  color: #FF8A5B;
  margin-bottom: 32rpx;
}

.empty-title {
  font-size: 34rpx;
  color: #4A3D32;
  font-weight: 600;
  margin-bottom: 12rpx;
  letter-spacing: 1rpx;
}

.empty-sub {
  font-size: 26rpx;
  color: #B5A99B;
  text-align: center;
  line-height: 1.7;
  max-width: 480rpx;
}

/* ── Recipe list ── */
.list {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
}

/* ── Recipe card ── */
.card {
  display: flex;
  gap: 28rpx;
  background: #fff;
  border-radius: 32rpx;
  padding: 32rpx;
  box-shadow: 0 4rpx 20rpx rgba(42, 33, 24, 0.055), 0 1rpx 4rpx rgba(42, 33, 24, 0.04);
  transition: transform 0.15s;
}

.card:active {
  transform: scale(0.982);
  box-shadow: 0 2rpx 8rpx rgba(42, 33, 24, 0.06);
}

.card-avatar {
  flex-shrink: 0;
  width: 136rpx;
  height: 136rpx;
  border-radius: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 24rpx rgba(255, 94, 58, 0.22);
}

.card-initial {
  font-size: 60rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.card-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.card-top {
  display: flex;
  align-items: flex-start;
  gap: 16rpx;
  margin-bottom: 10rpx;
}

.card-name {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #2A2118;
  line-height: 1.3;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 1;
  -webkit-box-orient: vertical;
  letter-spacing: 0.5rpx;
}

.card-fav {
  flex-shrink: 0;
  width: 60rpx;
  height: 60rpx;
  border-radius: 50%;
  background: #FBF4EC;
  display: flex;
  align-items: center;
  justify-content: center;
}

.card-fav-on {
  background: #FFE8DD;
}

.card-fav-icon {
  font-size: 30rpx;
  color: #D4C5B3;
  line-height: 1;
}

.card-fav-on .card-fav-icon {
  color: #FF5E3A;
}

.card-tag-row {
  margin-bottom: 10rpx;
}

.card-tag {
  display: inline-block;
  font-size: 22rpx;
  color: #FF6B35;
  background: #FFF0E6;
  padding: 5rpx 18rpx;
  border-radius: 10rpx;
  font-weight: 500;
}

.card-desc {
  font-size: 25rpx;
  color: #8A7865;
  line-height: 1.65;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  margin-bottom: 12rpx;
}

.card-meta {
  margin-top: auto;
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding-top: 12rpx;
  border-top: 1rpx solid #F5EEE6;
}

.card-meta-text {
  font-size: 23rpx;
  color: #C4B5A5;
  letter-spacing: 0.5rpx;
}

.card-arrow {
  font-size: 36rpx;
  color: #E0D0C0;
  line-height: 1;
}

/* ── List end ── */
.list-end {
  padding: 48rpx 0 24rpx;
  text-align: center;
}

.list-end-text {
  font-size: 22rpx;
  color: #D4C5B3;
  letter-spacing: 3rpx;
}
