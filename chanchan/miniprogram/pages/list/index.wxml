<view class="page">
  <view class="top-bg"></view>

  <view class="header">
    <view class="brand">
      <text class="brand-title">找道菜</text>
      <text class="brand-sub">挑一道菜，开启好胃口</text>
    </view>
    <view class="header-stat">
      <text class="stat-num">{{favCount}}</text>
      <text class="stat-label">已收藏</text>
    </view>
  </view>

  <view class="search-wrap">
    <view class="search">
      <text class="search-icon">⌕</text>
      <input
        class="search-input"
        placeholder="搜菜名、原料或类别"
        placeholder-class="search-placeholder"
        value="{{keyword}}"
        bindinput="onSearchInput"
        confirm-type="search"
      />
      <view wx:if="{{keyword}}" class="search-clear" bindtap="onClearSearch">
        <text class="search-clear-icon">×</text>
      </view>
    </view>
  </view>

  <view class="tabs">
    <view
      class="tab {{tab === 'all' ? 'tab-on' : ''}}"
      data-tab="all"
      bindtap="onTapTab"
    >
      <text class="tab-label">全部菜谱</text>
      <view wx:if="{{tab === 'all'}}" class="tab-dot"></view>
    </view>
    <view
      class="tab {{tab === 'fav' ? 'tab-on' : ''}}"
      data-tab="fav"
      bindtap="onTapTab"
    >
      <text class="tab-label">我的收藏</text>
      <text wx:if="{{favCount > 0}}" class="tab-badge">{{favCount}}</text>
      <view wx:if="{{tab === 'fav'}}" class="tab-dot"></view>
    </view>
  </view>

  <view class="list-wrap">
    <view wx:if="{{loading}}" class="state">
      <view class="state-dot"></view>
      <text class="state-text">正在加载菜谱…</text>
    </view>

    <view wx:elif="{{error}}" class="state">
      <text class="state-text error">{{error}}</text>
      <view class="state-btn" bindtap="onRefresh">重新加载</view>
    </view>

    <view wx:elif="{{filtered.length === 0 && tab === 'fav'}}" class="empty">
      <view class="empty-ico">♡</view>
      <text class="empty-title">还没有收藏的菜谱</text>
      <text class="empty-sub">点击菜谱卡片右上角的心形图标加入收藏</text>
    </view>

    <view wx:elif="{{filtered.length === 0 && keyword}}" class="empty">
      <view class="empty-ico">⌕</view>
      <text class="empty-title">没有匹配的菜谱</text>
      <text class="empty-sub">换个关键词试试看</text>
    </view>

    <view wx:elif="{{filtered.length === 0}}" class="empty">
      <view class="empty-ico">⌀</view>
      <text class="empty-title">暂无菜谱</text>
    </view>

    <view wx:else class="list">
      <view
        wx:for="{{filtered}}"
        wx:key="id"
        class="card"
        data-id="{{item.id}}"
        bindtap="onTapItem"
      >
        <view class="card-avatar" style="background: {{item._gradient}};">
          <text class="card-initial">{{item._initial}}</text>
        </view>

        <view class="card-body">
          <view class="card-top">
            <text class="card-name">{{item.cp_name}}</text>
            <view
              class="card-fav {{item._favorited ? 'card-fav-on' : ''}}"
              data-id="{{item.id}}"
              catchtap="onTapFav"
            >
              <text class="card-fav-icon">{{item._favorited ? '♥' : '♡'}}</text>
            </view>
          </view>

          <view wx:if="{{item.type_name}}" class="card-tag-row">
            <text class="card-tag">{{item.type_name}}</text>
          </view>

          <text wx:if="{{item._desc}}" class="card-desc">{{item._desc}}</text>

          <view wx:if="{{item._preview}}" class="card-meta">
            <text class="card-meta-text">{{item._preview}}</text>
            <text class="card-arrow">›</text>
          </view>
        </view>
      </view>
    </view>

    <view wx:if="{{loadingMore}}" class="list-end">
      <view class="state-dot"></view>
      <text class="list-end-text">正在加载更多…</text>
    </view>
    <view wx:elif="{{filtered.length > 0 && !hasMore}}" class="list-end">
      <text class="list-end-text">— 已显示全部 {{filtered.length}} 道菜 —</text>
    </view>
  </view>
</view>
