/* ============================================================
 *  今天吃什么（Recommend）
 *  · 大尺寸主 Hero 卡，食欲感渐变 + 高亮统计
 *  · 食材预览 chips
 *  · 底部主副按钮组 + 近期历史
 * ============================================================ */
page {
  background: var(--color-bg);
}

.page {
  position: relative;
  min-height: 100vh;
  padding: var(--sp-4) var(--sp-4) calc(160rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ── 背景柔光 ── */
.bg-decor {
  position: absolute;
  top: 0;
  left: 0;
  right: 0;
  height: 520rpx;
  background: var(--grad-bg-warm);
  z-index: 0;
}

.bg-decor::after {
  content: '';
  position: absolute;
  top: 40rpx;
  right: -80rpx;
  width: 300rpx;
  height: 300rpx;
  background: radial-gradient(circle, rgba(255, 170, 120, 0.22), rgba(255, 170, 120, 0) 70%);
  border-radius: 50%;
}

/* ── 顶部 ── */
.topbar {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
  padding: var(--sp-2) 8rpx 12rpx;
}

.topbar-left { display: flex; flex-direction: column; }

.topbar-date {
  font-size: 23rpx;
  color: var(--color-text-4);
  letter-spacing: 1rpx;
}

.topbar-title {
  margin-top: 8rpx;
  font-size: var(--fs-display);
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: 2rpx;
  line-height: 1.2;
}

.topbar-fav {
  display: flex;
  align-items: center;
  gap: 10rpx;
  background: var(--color-surface);
  padding: 14rpx 26rpx;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-md);
}

.topbar-fav-icon {
  font-size: 28rpx;
  color: var(--color-primary);
  line-height: 1;
}

.topbar-fav-num {
  font-size: 26rpx;
  color: var(--color-text-2);
  font-weight: 600;
  line-height: 1;
}

/* ── 当前餐段 ── */
.slot-row {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  gap: 18rpx;
  padding: var(--sp-3) 8rpx var(--sp-4);
}

.slot-chip {
  background: var(--grad-primary);
  padding: 10rpx 24rpx;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-primary);
}

.slot-label {
  font-size: var(--fs-small);
  color: #fff;
  font-weight: 600;
  letter-spacing: 1rpx;
}

.slot-hint {
  font-size: var(--fs-small);
  color: var(--color-text-3);
  letter-spacing: 0.5rpx;
}

/* ── 状态 ── */
.state {
  padding: 140rpx 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: var(--sp-3);
}

.state-dot {
  width: 52rpx;
  height: 52rpx;
  border-radius: 50%;
  border: 4rpx solid #FFD4BF;
  border-top-color: var(--color-primary);
  animation: spin 0.8s linear infinite;
}

@keyframes spin { to { transform: rotate(360deg); } }

.state-text { font-size: var(--fs-body); color: var(--color-text-3); }
.state-text.error { color: var(--color-error); }

.state-btn {
  margin-top: 8rpx;
  padding: 20rpx 48rpx;
  background: var(--grad-primary);
  color: #fff;
  font-size: var(--fs-body);
  font-weight: 500;
  border-radius: var(--r-full);
  box-shadow: var(--shadow-primary);
}

/* ── Hero 主卡 ── */
.hero {
  position: relative;
  z-index: 1;
  margin-top: 4rpx;
  border-radius: var(--r-2xl);
  overflow: hidden;
  box-shadow: 0 24rpx 64rpx rgba(255, 94, 58, 0.28);
}

.hero-inner {
  position: relative;
  padding: var(--sp-5) var(--sp-5) var(--sp-4);
  color: #fff;
  overflow: hidden;
}

.hero-inner::before {
  content: '';
  position: absolute;
  right: -100rpx;
  top: -100rpx;
  width: 400rpx;
  height: 400rpx;
  background: rgba(255, 255, 255, 0.12);
  border-radius: 50%;
}

.hero-inner::after {
  content: '';
  position: absolute;
  left: -60rpx;
  bottom: -80rpx;
  width: 280rpx;
  height: 280rpx;
  background: rgba(255, 255, 255, 0.08);
  border-radius: 50%;
}

.hero-top {
  position: relative;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.hero-tag {
  font-size: var(--fs-small);
  color: #fff;
  background: rgba(255, 255, 255, 0.24);
  padding: 9rpx 24rpx;
  border-radius: var(--r-full);
  font-weight: 500;
  letter-spacing: 0.5rpx;
}

.fav-btn {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.22);
  display: flex;
  align-items: center;
  justify-content: center;
  transition: transform 0.2s;
}

.fav-btn.fav-on { background: #fff; }
.fav-btn:active { transform: scale(0.9); }

.fav-icon {
  font-size: 38rpx;
  color: #fff;
  line-height: 1;
}

.fav-btn.fav-on .fav-icon {
  color: var(--color-primary);
}

.hero-body {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-4);
  display: flex;
  flex-direction: column;
  align-items: flex-start;
}

.hero-badge {
  width: 120rpx;
  height: 120rpx;
  border-radius: var(--r-lg);
  background: rgba(255, 255, 255, 0.24);
  display: flex;
  align-items: center;
  justify-content: center;
  border: 2rpx solid rgba(255, 255, 255, 0.30);
}

.hero-initial {
  font-size: 60rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.hero-name {
  margin-top: var(--sp-4);
  font-size: var(--fs-display);
  font-weight: 700;
  color: #fff;
  line-height: 1.2;
  letter-spacing: 2rpx;
}

.hero-sub {
  margin-top: 14rpx;
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.88);
  line-height: 1.65;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* ── 统计行 ── */
.stats-row {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-5);
  display: flex;
  align-items: center;
  background: rgba(255, 255, 255, 0.18);
  border-radius: var(--r-lg);
  padding: 26rpx 0;
  backdrop-filter: blur(6rpx);
  -webkit-backdrop-filter: blur(6rpx);
}

.stat { flex: 1; display: flex; flex-direction: column; align-items: center; }

.stat-num {
  font-size: var(--fs-h1);
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.stat-label {
  margin-top: 8rpx;
  font-size: var(--fs-tiny);
  color: rgba(255, 255, 255, 0.84);
  letter-spacing: 0.5rpx;
}

.stat-divider {
  width: 1.5rpx;
  height: 48rpx;
  background: rgba(255, 255, 255, 0.24);
}

/* ── CTA ── */
.hero-cta {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-4);
  padding: 18rpx 0 6rpx;
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  border-top: 1.5rpx solid rgba(255, 255, 255, 0.20);
}

.hero-cta-text {
  font-size: 26rpx;
  color: rgba(255, 255, 255, 0.94);
  font-weight: 500;
}

.hero-cta-arrow {
  font-size: 28rpx;
  color: #fff;
  line-height: 1;
}

/* ── 食材预览 ── */
.preview-card {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-3);
  background: var(--color-surface);
  border-radius: var(--r-xl);
  padding: var(--sp-4) var(--sp-4) 28rpx;
  box-shadow: var(--shadow-md);
}

.preview-head {
  display: flex;
  align-items: center;
  margin-bottom: 22rpx;
}

.preview-bar {
  width: 6rpx;
  height: 30rpx;
  background: var(--grad-primary);
  border-radius: 3rpx;
  margin-right: 16rpx;
}

.preview-title {
  font-size: 30rpx;
  font-weight: 700;
  color: var(--color-text-1);
  letter-spacing: 0.5rpx;
}

.preview-chips {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.preview-chips-alt { margin-top: 16rpx; }

.preview-chip {
  font-size: var(--fs-small);
  color: var(--color-text-2);
  background: var(--color-primary-bg);
  padding: 11rpx 22rpx;
  border-radius: var(--r-md);
  border: 1rpx solid var(--color-border-warm);
}

.preview-chip-alt {
  background: var(--color-accent-bg);
  color: #8A5A2B;
  border-color: var(--color-accent-bd);
}

.preview-more {
  font-size: var(--fs-small);
  color: var(--color-text-4);
  padding: 11rpx 20rpx;
  background: var(--color-surface-soft);
  border-radius: var(--r-md);
}

/* ── 操作按钮 ── */
.btn-row {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-3);
  display: flex;
  gap: 16rpx;
}

.btn {
  flex: 1;
  height: 100rpx;
  border-radius: var(--r-xl);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 12rpx;
  font-weight: 600;
  transition: opacity 0.15s, transform 0.15s;
}

.btn:active { opacity: 0.9; transform: scale(0.98); }

.btn-primary {
  background: var(--grad-primary);
  color: #fff;
  box-shadow: var(--shadow-primary);
}

.btn-ghost {
  background: var(--color-surface);
  color: var(--color-primary);
  border: 1.5rpx solid var(--color-border-warm);
}

.btn-disabled { opacity: 0.55; }

.btn-ico { font-size: 34rpx; line-height: 1; }
.btn-label { font-size: 30rpx; }

/* ── 历史记录 ── */
.history {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-5);
}

.history-head { padding: 0 4rpx 18rpx; }

.history-title {
  font-size: 26rpx;
  color: var(--color-text-3);
  font-weight: 600;
  letter-spacing: 1rpx;
}

.history-scroll { white-space: nowrap; }

.history-item {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 188rpx;
  margin-right: 16rpx;
  padding: var(--sp-3) 16rpx 20rpx;
  background: var(--color-surface);
  border-radius: var(--r-lg);
  box-shadow: var(--shadow-sm);
  transition: opacity 0.15s, transform 0.15s;
}

.history-item:active { opacity: 0.8; transform: scale(0.97); }

.history-avatar {
  width: 100rpx;
  height: 100rpx;
  border-radius: var(--r-md);
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 18rpx rgba(255, 94, 58, 0.24);
}

.history-initial {
  font-size: 44rpx;
  font-weight: 700;
  color: #fff;
  line-height: 1;
}

.history-name {
  margin-top: 16rpx;
  font-size: 25rpx;
  color: var(--color-text-1);
  font-weight: 500;
  max-width: 168rpx;
  overflow: hidden;
  white-space: nowrap;
  text-overflow: ellipsis;
  text-align: center;
}

.history-tag {
  margin-top: 6rpx;
  font-size: 21rpx;
  color: var(--color-text-4);
}

/* ── 底部 ── */
.tip-row {
  position: relative;
  z-index: 1;
  margin-top: var(--sp-6);
  padding: 8rpx 0;
  text-align: center;
}

.tip-text {
  font-size: var(--fs-tiny);
  color: var(--color-text-5);
  letter-spacing: 1rpx;
}
